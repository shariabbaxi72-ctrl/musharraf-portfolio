# Copy this file to ".env" (same folder) and fill in YOUR OWN EmailJS keys.
# Get these from https://www.emailjs.com after creating a free account:
# 1. Email Services -> Add New Service -> connect your Gmail inbox -> copy the Service ID
# 2. Email Templates -> Create New Template -> use {{from_name}}, {{from_email}}, {{message}}, {{to_name}} -> copy the Template ID
# 3. Account -> General -> copy your Public Key

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
